---
/*
 * HeroFullBleed — The Opening Shot
 *
 * Full-screen image with text overlay. The cold open.
 * The image has one job: emotional capture in under five seconds.
 *
 * Design: full-bleed, viewport-height, dark placeholder respecting
 * intended aspect ratio and low-key lighting. Text overlay centered
 * or positioned as needed. Accommodates 2-3 sentence statements,
 * not fixed character counts.
 */

interface Props {
  /** Image source — when ready, a real photograph. For now, a dark placeholder. */
  imageSrc?: string;
  /** Alt text for the hero image */
  imageAlt?: string;
  /** The overlay text — the sentence that opens a door */
  overlayText?: string;
  /** Optional smaller text above or below the main overlay */
  subtitle?: string;
  /** Vertical position of text: 'center' | 'lower' */
  textPosition?: 'center' | 'lower';
}

const {
  imageSrc,
  imageAlt = '',
  overlayText = '[PLACEHOLDER — Hero overlay text]',
  subtitle,
  textPosition = 'lower',
} = Astro.props;
---

<section class="hero-full-bleed relative w-full min-h-screen overflow-hidden">
  <!-- Image layer -->
  {imageSrc ? (
    <img
      src={imageSrc}
      alt={imageAlt}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
  ) : (
    <!-- Placeholder: dark gradient suggesting low-key cinematic lighting -->
    <div class="absolute inset-0 bg-gradient-to-b from-charcoal-deep via-charcoal to-metallic-oil"></div>
    <!-- Subtle texture overlay to avoid flat emptiness -->
    <div class="absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle at 30% 40%, rgba(168,136,74,0.3) 0%, transparent 60%), radial-gradient(circle at 70% 60%, rgba(74,63,82,0.2) 0%, transparent 50%);">
    </div>
  )}

  <!-- Gradient overlay for text legibility -->
  <div class="absolute inset-0 bg-gradient-to-t from-charcoal-deep/80 via-transparent to-charcoal-deep/30"></div>

  <!-- Text overlay -->
  <div class:list={[
    'relative z-10 flex flex-col max-w-content mx-auto px-5 md:px-8 lg:px-12 min-h-screen',
    textPosition === 'center' ? 'justify-center' : 'justify-end pb-20 md:pb-28 lg:pb-32',
  ]}>
    {subtitle && (
      <p class="text-nav font-body font-medium uppercase tracking-widest text-amber-pale/70 mb-4">
        {subtitle}
      </p>
    )}
    <p class="text-display-md md:text-display-lg font-display text-cream max-w-prose-wide leading-snug">
      {overlayText}
    </p>
  </div>
</section>

<style>
  .hero-full-bleed {
    /* Ensure true viewport height on mobile */
    min-height: 100vh;
    min-height: 100dvh;
  }
</style>
